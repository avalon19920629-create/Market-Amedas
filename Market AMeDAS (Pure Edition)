        print(f"1. 風向き (米ドル)    : {wind}")
        print(f"2. 酸素濃度 (ジャンク): {oxygen}")
        print(f"3. 地熱 (小型株)      : {ground}")
        print("-" * 72)

        print("\n📋 構造分析ログ")
        sorted_assets = sorted(detailed_assets, key=lambda x: x['Score'], reverse=True)
        updrafts = [a for a in sorted_assets if a['Score'] > EPSILON and a['Season'] != "Env"]
        downdrafts = [a for a in sorted_assets if a['Score'] < -EPSILON and a['Season'] != "Env"]

        print("\n📈 [上昇流 - Updrafts]")
        if updrafts:
            for a in updrafts:
                s_name = labels.get(a['Season'], "その他")[:2]
                role = get_contribution_label(a['Contrib_Val'], season_pressure.get(a['Season'], {}).get("positive", 1))
                print(f"  {role} {a['Name']:<6} [{s_name}] : +{a['Score']:.2f}")
        else:
            print("  なし")

        print("\n📉 [下降流 - Downdrafts]")
        if downdrafts:
            for a in downdrafts:
                s_name = labels.get(a['Season'], "その他")[:2]
                print(f"  ・崩し {a['Name']:<6} [{s_name}] : {a['Score']:.2f}")
        else:
            print("  なし")

        plot_net_pressure_distribution(season_pressure)

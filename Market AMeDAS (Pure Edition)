            print(f"  {labels[s]:<10} : {ratio:5.1f}%")

        print("-" * 72)
        if is_storm:
            print("⛈️ 【警報】暴風域 (VIX > 25) 発生中。防衛気団が支配的です。")
        btc_mode = "リスクオン (Spring)" if btc_w['Spring'] > 0.5 else "デジタルゴールド (Summer)"
